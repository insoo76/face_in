   "source": [
    "## 🎨 2단계: 핵심 모듈 로드 및 윈도우 한글 폰트 설정\n",
    "\n",
    "인공지능 모델 구동과 시각화에 필수적인 패키지들을 로드하고, 차트가 그려질 때 한글이 깨지는 현상을 방지하기 위해 **맑은 고딕(Malgun Gothic)** 폰트 설정을 안전하게 적용합니다."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "import sys\n",
    "import random\n",
    "import time\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from PIL import Image\n",
    "from tqdm import tqdm\n",
    "\n",
    "# 딥러닝 구동용 PyTorch\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "import torchvision.transforms as transforms\n",
    "from torchvision import models\n",
    "from torchvision.datasets import ImageFolder\n",
    "from torch.utils.data import DataLoader\n",
    "\n",
    "# 평가 통계 모듈\n",
    "from sklearn.metrics import confusion_matrix, classification_report\n",
    "\n",
    "# 💻 Windows OS 기반 맑은 고딕 폰트 적용 및 마이너스 깨짐 방지\n",
    "plt.rc('font', family='Malgun Gothic')\n",
    "plt.rc('axes', unicode_minus=False)\n",
    "\n",
    "print(f\"🔥 PyTorch 버전: {torch.__version__}\")\n",
    "print(\"✅ 시각화 및 평가를 위한 모든 라이브러리가 성공적으로 활성화되었습니다!\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 🧬 3단계: EfficientNet-B0 모델 아키텍처 정의\n",
    "\n",
    "학습 시 사용되었던 동일한 구조를 수립합니다. 사전 학습된 고성능 `EfficientNet-B0`를 불러와 마지막 출력 레이어(Classifier)의 최종 차원을 **원래 학습할 때의 전체 클래스 수(7개)**에 맞게 조립합니다."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def get_emotion_efficientnet(num_classes=7):\n",
    "    \"\"\"\n",
    "    사전 학습된 고성능 이미지 인식 모델 EfficientNet-B0를 로드하고,\n",
    "    가중치 파일에 저장된 원래의 감정 분류 클래스 개수(7개)에 맞춰 마지막 선형 레이어(Linear Layer)를 개조하는 함수입니다.\n",
    "    \"\"\"\n",
    "    # ImageNet으로 선행 학습된 탄탄한 기본 가중치 다운로드 및 모델 선언\n",
    "    model = models.efficientnet_b0(weights=models.EfficientNet_B0_Weights.DEFAULT)\n",
    "    \n",
    "    # 최종 분류 직전의 입력 특징 벡터 차원(1280차원) 크기 확보\n",
    "    in_features = model.classifier[1].in_features\n",
    "    \n",
    "    # 7개의 원래 감정 클래스를 올바르게 구별하도록 맨 마지막 출력단을 새로운 선형 계층으로 정교하게 대체\n",
    "    model.classifier[1] = nn.Linear(in_features, num_classes)\n",
    "    \n",
    "    return model\n",
    "\n",
    "print(\"✨ EfficientNet-B0 개조 빌더 함수가 성공적으로 구성되었습니다.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 📂 4단계: 테스트 데이터셋 탑재 및 평가 전처리 정의\n",
    "\n",
    "학습과 검증에 관여하지 않은 순수한 평가용 이미지 폴더(`data/test`)를 가져옵니다.\n",
    "이때, 학습용에 넣었던 데이터 증강(데이터 늘리기 왜곡)을 제외하고, 해상도 크기 조정(`224x224`)과 신경망 분석 표준 정규화만 정교하게 대입합니다."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 테스트 데이터 디렉토리 경로 지정\n",
    "test_dir = 'data/test'\n",
    "\n",
    "# 1. 실전 테스트용 이미지 전처리(Transforms) 수립\n",
    "# 데이터 왜곡 기법 없이 깔끔하게 224 크기로 축소/정규화하여 안정성을 확보합니다.\n",
    "test_transforms = transforms.Compose([\n",
    "    transforms.Resize((224, 224)),\n",
    "    transforms.ToTensor(),\n",
    "    transforms.Normalize(\n",
    "        mean=[0.485, 0.456, 0.406],\n",
    "        std=[0.229, 0.224, 0.225]\n",
    "    )\n",
    "])\n",
    "\n",
    "if not os.path.exists(test_dir):\n",
    "    print(f\"❌ [오류] '{test_dir}' 경로를 찾을 수 없습니다.\")\n",
    "    print(\"가이드: 먼저 데이터셋이 정상적으로 분할되었는지 데이터 세트 폴더를 확인해 주세요.\")\n",
    "else:\n",
    "    # 2. PyTorch ImageFolder 구조를 사용해 테스트 이미지 폴더 매핑\n",
    "    test_dataset = ImageFolder(root=test_dir, transform=test_transforms)\n",
    "    \n",
    "    # 3. 미니배치(Batch Size=32) 단위로 공급할 고성능 DataLoader 적재\n",
    "    test_loader = DataLoader(test_dataset, batch_size=32, shuffle=False, num_workers=0)\n",
    "    \n",
    "    print(\"=== 📂 테스트용 데이터 로딩 완료 ===\")\n",
    "    print(f\"- 🔬 실전 테스트용 이미지 개수 : {len(test_dataset):,}장 (배치 묶음: {len(test_loader)}개)\")\n",
    "    print(f\"- 🏷️ 테스트셋 폴더명 정보     : {test_dataset.classes} (총 {len(test_dataset.classes)}개 감정 폴더)\")\n",
    "    print(f\"- 📊 감정 클래스 색인 정보      : {test_dataset.class_to_idx}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 💾 5단계: 최적 가중치 파일(Weight File) 검색 및 안전한 로드(Load)\n",
    "\n",
    "학습 과정에서 디스크에 저장한 가중치 파일을 탐색합니다. `best_emotion_model.pth` 또는 `model.pth` 파일을 자동 검색하여 인공지능 신경망에 장착하고 연산 가속을 위해 GPU(존재 시) 장치로 이식합니다."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 1. 하드웨어 가속기(GPU/CUDA) 자동 감지\n",
    "device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n",
    "print(f\"⚡ 연산 가속 디바이스: [{device.type.upper()}]\")\n",
    "if device.type == 'cuda':\n",
    "    print(f\"  - 그래픽 카드 사양: {torch.cuda.get_device_name(0)}\")\n",
    "\n",
    "# 2. 가중치 파일 후보 탐색\n",
    "model_candidates = ['best_emotion_model.pth', 'model.pth']\n",
    "selected_model_path = None\n",
    "\n",
    "for candidate in model_candidates:\n",
    "    if os.path.exists(candidate):\n",
    "        selected_model_path = candidate\n",
    "        break\n",
    "\n",
    "if selected_model_path is None:\n",
    "    print(\"❌ [오류] 폴더 내에서 학습 완료된 가중치 파일('best_emotion_model.pth' 또는 'model.pth')을 찾을 수 없습니다!\")\n",
    "    print(\"가이드: 학습용 스크립트(train.py 등)를 끝까지 구동하시어 모델 파일을 먼저 생성해 주시기 바랍니다.\")\n",
    "else:\n",
    "    print(f"🎯 검색된 가중치 파일 적용: [{selected_model_path}]\")\n",
    "    \n",
    "    # 3. 평가용 빈 껍데기 모델 구축\n",
    "    # 💡 [핵심 안전 조치] 학습 시 가중치 구조(7개 감정 클래스)로 아예 상수를 7로 고정하여 껍데기 모델을 선언합니다.\n",
    "    # 이를 통해 데이터셋 폴더 수와 가중치 간의 불일치로 인한 Size Mismatch 에러를 원천 봉쇄합니다.\n",
    "    evaluation_model = get_emotion_efficientnet(num_classes=7)\n",
    "    \n",
    "    # 4. 저장된 가중치를 껍데기 신경망에 완벽 이식\n",
    "    evaluation_model.load_state_dict(torch.load(selected_model_path, map_location=device))\n",
    "    evaluation_model.to(device)\n",
    "    \n",
    "    # 5. 모델을 평가(Evaluation) 모드로 전환 (훈련용 드롭아웃 등 비활성화)\n",
    "    evaluation_model.eval()\n",
    "    print(f\"✅ 최적 가중치 파일 로딩 완료 및 GPU 이식 성공!\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 📊 6단계: 실전 테스트 데이터 평가 및 정량적 종합 분석 리포트\n",
    "\n",
    "테스트 데이터를 모델에 통과시켜 각 이미지별 예측 결과를 연산합니다.\n",
    "\n",
    "> **💡 클래스 인덱스 보정 매핑 기술**:\n",
    "> `ImageFolder`는 데이터셋 폴더인 `['0', '2', '3', '4']`를 내부적으로 0~3 인덱스로 임의 재배치합니다. 하지만 학습 완료된 원래 모델은 폴더명 자체가 실제 감정 인덱스(0, 2, 3, 4)로 동작하므로, 불러온 `labels` 값을 원래 감정 폴더 정수(0, 2, 3, 4)로 매핑한 뒤 모델의 예측값(0~6 범위)과 대조해야 정확하게 성능을 산출할 수 있습니다!"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 감정 인덱스 번호를 직관적인 한국어 감정명으로 변환하는 사전(Dictionary) 정의\n",
    "EMOTION_MAP = {\n",
    "    '0': '화남 (Angry)',\n",
    "    '1': '혐오 (Disgust)',\n",
    "    '2': '공포 (Fear)',\n",
    "    '3': '기쁨 (Happy)',\n",
    "    '4': '슬픔 (Sad)',\n",
    "    '5': '놀람 (Surprise)',\n",
    "    '6': '무표정 (Neutral)'\n",
    "}\n",
    "\n",
    "# 전체 테스트 데이터에 대한 예측 통계 수집 리스트\n",
    "all_preds = []\n",
    "all_labels = []\n",
    "all_confidences = [] # 모델의 예측 확신도\n",
    "\n",
    "total_test_corrects = 0\n",
    "\n",
    "print(\"🚀 [평가 단계] 실전 테스트 데이터셋 예측 연산을 시작합니다...\")\n",
    "\n",
    "# 역전파 그라디언트 계산을 중단하여 속도 향상 및 메모리 절약\n",
    "with torch.no_grad():\n",
    "    for inputs, labels in tqdm(test_loader, desc=\"🔬 테스트 데이터 연산 중\"):\n",
    "        inputs = inputs.to(device)\n",
    "        \n",
    "        # 💡 [핵심 교정] ImageFolder가 임의 부여한 인덱스(0~3)를 원래 폴더명 정수값(0, 2, 3, 4)으로 변환\n",
    "        mapped_labels = torch.tensor([int(test_dataset.classes[l]) for l in labels]).to(device)\n",
    "        \n",
    "        # 순전파 예측 수행 (모델 출력 크기는 7차원)\n",
    "        outputs = evaluation_model(inputs)\n",
    "        \n",
    "        # Softmax 연산으로 점수를 확률(0~1)로 정규화\n",
    "        probabilities = torch.softmax(outputs, dim=1)\n",
    "        \n",
    "        # 가장 높은 확률값과 해당 클래스 인덱스 추출 (0~6 범위)\n",
    "        confidences, preds = torch.max(probabilities, 1)\n",
    "        \n",
    "        # 보정된 실제 라벨 데이터와 인공지능 예측 데이터 일치 여부 비교\n",
    "        total_test_corrects += torch.sum(preds == mapped_labels.data)\n",
    "        \n",
    "        # CPU 메모리로 내려 파이썬 데이터로 변환 후 수집\n",
    "        all_preds.extend(preds.cpu().numpy())\n",
    "        all_labels.extend(mapped_labels.cpu().numpy())\n",
    "        all_confidences.extend(confidences.cpu().numpy())\n",
    "\n",
    "final_test_acc = total_test_corrects.double() / len(test_dataset)\n",
    "print(f\"\\n🎉 실전 테스트 완료! 최종 정확도(Accuracy): {final_test_acc:.4f} ({final_test_acc*100:.2f}%)\")\n",
    "\n",
    "print(\"\\n====================== 🏆 정량적 종합 인공지능 평가 리포트 ======================\")\n",
    "# 실제로 테스트 셋에 존재하는 감정 라벨들만 추출하여 리포트에 매핑합니다.\n",
    "unique_present_labels = sorted(list(set(all_labels)))\n",
    "target_report_names = [EMOTION_MAP.get(str(l), f\"라벨 {l}\") for l in unique_present_labels]\n",
    "\n",
    "# 상세 리포트 출력\n",
    "print(classification_report(\n",
    "    all_labels, \n",
    "    all_preds, \n",
    "    labels=unique_present_labels, \n",
    "    target_names=target_report_names, \n",
    "    digits=4\n",
    "))\n",
    "print(\"=================================================================================\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 📈 7단계: 한글 혼돈행렬(Confusion Matrix) 시각화\n",
    "\n",
    "인공지능이 실제 감정을 감지할 때 어떤 표정을 특히 헷갈려하고 실수했는지 한눈에 파악할 수 있는 **혼돈행렬 히트맵**을 그립니다.\n",
